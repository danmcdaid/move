#!/bin/bash

# Directory to store downloaded .deb files
DOWNLOAD_DIR="/tmp/apt-downloads"
mkdir -p "$DOWNLOAD_DIR"

# Function to download a package from packages.debian.org
download_package() {
    local package=$1
    
    # Extract the US HTTP mirror URL
    deb_url=$(echo "$HTML_CONTENT" | grep -oP 'href="http://http\.us\.debian\.org/debian/pool/main/[^"]+\.deb"' | head -n 1 | sed 's/href="//;s/"$//')
    
    if [ -n "$deb_url" ]; then
        echo "Downloading $package from $deb_url"
        wget -O "${DOWNLOAD_DIR}/$(basename $deb_url)" "$deb_url"
    else
        echo "Failed to find download URL for $package" >&2
        return 1
    fi
}

# Main script
download_package "zsh-common"

# Print the directory containing downloads
echo "Downloads are in $DOWNLOAD_DIR"
